# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=intelliknow

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Crawler Settings
CRAWL_INTERVAL_EARTHQUAKE=3600
CRAWL_INTERVAL_ACADEMIC=86400
CRAWL_INTERVAL_NEWS=7200

# Deduplication
DUPLICATE_THRESHOLD=0.85

# Translation Service (optional)
# Options: google (MyMemory free), deepl
TRANSLATION_PROVIDER=google
# DEEPL_API_KEY=your_deepl_api_key  # Optional: for better translation quality
