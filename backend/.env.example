# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=intelliknow

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Crawler Settings
CRAWL_INTERVAL_EARTHQUAKE=3600
CRAWL_INTERVAL_ACADEMIC=86400
CRAWL_INTERVAL_NEWS=7200

# Deduplication
DUPLICATE_THRESHOLD=0.85

# Translation Service
# Priority order: gemma -> mymemory -> baidu -> tencent -> youdao -> deepl -> google
# First available provider will be used
TRANSLATION_PROVIDER=gemma

# ============================================
# FREE Providers (No API key required!)
# ============================================

# Gemma Translate (RECOMMENDED - Fast AI translation)
# Apply at: https://gemmatranslate.org
# No signup needed, free for 500K+ translations/day
# NOTE: This is the best free option, no configuration needed
# ============================================

# PAID Domestic Providers (with free tiers)

# Baidu Translation API (2M chars/month free)
# Apply at: https://fanyi.baidu.com
BAIDU_TRANSLATE_APPID=your_baidu_appid
BAIDU_TRANSLATE_SECRET=your_baidu_secret

# Tencent Cloud Translation API (500K chars/month free)
# Apply at: https://cloud.tencent.com/product/tmt
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_REGION=ap-guangzhou

# Youdao Translation API (free tier available)
# Apply at: https://ai.youdao.com
YOUDAO_APPKEY=your_youdao_appkey
YOUDAO_APPSECRET=your_youdao_appsecret

# PAID Foreign Providers

# DeepL API (50K chars/month free)
# Apply at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key
